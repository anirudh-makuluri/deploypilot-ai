# LLM / runtime
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-west-2
BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0

# Data store
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional GitHub auth for private repos / higher API limits
GITHUB_TOKEN=ghp_your_github_token

# API auth
SD_API_BEARER_TOKEN=replace_with_secure_random_token

# Scope guard for broad root-level monorepo scans
SD_SCOPE_GUARD_ENABLED=true
SD_SCOPE_GUARD_TREE_THRESHOLD=3000
SD_SCOPE_GUARD_PACKAGE_THRESHOLD=20

# Fetch controls (minimal deploy-relevant files by default)
SD_FETCH_MARKDOWN=false
SD_INCLUDE_ROOT_CONFIG_FOR_PACKAGE=true

# GitHub API request policy
SD_GITHUB_CONNECT_TIMEOUT_SECONDS=5
SD_GITHUB_READ_TIMEOUT_SECONDS=20
SD_GITHUB_HTTP_ATTEMPTS=3
SD_GITHUB_RETRY_BACKOFF_SECONDS=0.5

# Raw content request policy
SD_GITHUB_RAW_CONNECT_TIMEOUT_SECONDS=3
SD_GITHUB_RAW_READ_TIMEOUT_SECONDS=8
SD_GITHUB_RAW_HTTP_ATTEMPTS=2
SD_GITHUB_RAW_RETRY_BACKOFF_SECONDS=0.2
SD_GITHUB_RAW_MAX_WORKERS=6
